{
  "name": "threat-monitoring-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "merge-openapi": "npx openapi-merge-cli --config ./src/swagger/openapi.config.json",
    "codegen:api": "node ./src/codegen/codegen.js",
    "codegen": "npm run merge-openapi && npm run codegen:api"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.16.0",
    "bootstrap": "^5.3.2",
    "react": "^18.3.1",
    "react-bootstrap": "^2.9.0",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "openapi-merge-cli": "^1.3.2",
    "openapi-typescript": "^7.13.0",
    "swagger-typescript-api": "^13.7.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.1"
  }
}
